{
	"name": "fancyfeet",
	"version": "2.0.0",
	"private": true,
	"scripts": {
		"dev": "tinacms dev -c \"vite dev\"",
		"build": "svelte-kit sync && tinacms build && vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.0.10",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.8"
	},
	"type": "module",
	"dependencies": {
		"@fontsource-variable/fira-code": "^5.2.7",
		"@fontsource-variable/quicksand": "^5.2.10",
		"@tinacms/cli": "^2.2.2",
		"feed": "^5.2.0",
		"lucide-svelte": "^1.0.1",
		"open-props": "^1.7.23",
		"tinacms": "^3.3.2"
	},
	"trustedDependencies": [
		"core-js",
		"protobufjs",
		"svelte-preprocess"
	]
}
